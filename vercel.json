{
  "buildCommand": "npm install && cd mobile-pwa && npm run build && cd ../desktop && npm run build",
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    { "src": "/desktop/assets/(.*)", "dest": "/desktop-dist/assets/$1" },
    { "src": "/desktop(/.*)?", "dest": "/desktop-dist/index.html" },
    { "handle": "filesystem" }
  ]
}
