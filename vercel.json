{
  "buildCommand": "npm install && cd mobile-pwa && npm run build && cd ../desktop && npm run build",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/desktop/assets/:path*", "destination": "/desktop-dist/assets/:path*" },
    { "source": "/desktop/:path*", "destination": "/desktop-dist/index.html" },
    { "source": "/desktop", "destination": "/desktop-dist/index.html" },
    { "source": "/mobile/:path*", "destination": "/mobile/:path*" }
  ]
}
